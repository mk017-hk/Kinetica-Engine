#include <windows.h>

// Application icon
IDI_APPICON ICON "assets/hm_studio.ico"

// Version information
VS_VERSION_INFO VERSIONINFO
    FILEVERSION    1,0,0,0
    PRODUCTVERSION 1,0,0,0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0x0L
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "HyperMotion"
            VALUE "FileDescription",  "HyperMotion Studio - Motion Capture & Animation"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "hm_studio"
            VALUE "OriginalFilename", "hm_studio.exe"
            VALUE "ProductName",      "HyperMotion Studio"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

// Application manifest for DPI awareness and modern controls
CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "hm_studio.manifest"
